<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    <header class="topbar">
      <div class="container">
        <div class="brand">
          <h1><%= title %></h1>
          <p class="tagline">Crie um usuário novo em poucos segundos</p>
        </div>
        <nav class="nav">
          <a href="/" class="nav-link">Início</a>
          <a href="/users/new" class="nav-link">Novo usuário</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <section class="card">
        <h2>Adicionar usuário</h2>
        <form action="/users/create" method="post">
          <label for="nome">Nome</label>
          <input id="nome" name="nome" required placeholder="Seu nome" />

          <label for="email">E-mail</label>
          <input id="email" name="email" type="email" required placeholder="seu@exemplo.com" />

          <button class="button" type="submit">Criar usuário</button>
        </form>
      </section>
    </main>

    <footer class="footer">
      <div class="container">
        <small>Feito com <span aria-label="coração">💜</span> e Express + EJS</small>
      </div>
    </footer>
  </body>
</html>
