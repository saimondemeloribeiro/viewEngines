<header class="page-header">
  <h1>{{title}}</h1>
  <p class="subtitle">Usuário criado com sucesso!</p>
</header>

<section class="card">
  <h2>Detalhes do usuário</h2>
  <p><strong>Nome:</strong> {{nome}}</p>
  <p><strong>E-mail:</strong> {{email}}</p>

  <div style="margin-top: 18px;">
    <a class="button" href="/users/new">Criar outro</a>
    <a class="button" href="/users" style="margin-left: 10px; background: rgba(255,255,255,0.14);">Ver usuários</a>
  </div>
</section>
